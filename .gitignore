playwright-report/
playwright/.cache/

# --- Env / secrets / signing keys (never commit) ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# --- OS cruft ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Editors ---
.vscode/*
!.vscode/extensions.json
.idea/
*.swp

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
