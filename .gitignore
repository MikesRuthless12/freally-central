# --- Node / Vite / UI ---
node_modules/
dist/
dist-ssr/
.vite/
*.tsbuildinfo

# --- Tauri ---
src-tauri/target/
src-tauri/gen/
src-tauri/WixTools/

# --- Playwright / e2e ---
